{
  "$schema": "https://schemas.babelsuite.dev/mock-exchange-source-v1.json",
  "adapter": "rest",
  "artifact": "mock/catalog/list-products.json",
  "contractPath": "api/openapi/orders.yaml#/paths/~1catalog~1products/get",
  "dispatcher": "apisix",
  "examples": {
    "promo-grid": {
      "dispatch": [
        {
          "from": "query",
          "param": "scenario",
          "value": "promo"
        }
      ],
      "requestSchema": {
        "body": {
          "type": "null"
        },
        "headers": {
          "properties": {
            "accept": {
              "example": "application/json",
              "type": "string"
            },
            "x-suite-profile": {
              "example": "promo.yaml",
              "type": "string"
            }
          },
          "required": [
            "accept",
            "x-suite-profile"
          ],
          "type": "object"
        }
      },
      "responseSchema": {
        "body": {
          "properties": {
            "campaign": {
              "example": "spring-promo",
              "type": "string"
            },
            "products": {
              "items": {
                "properties": {
                  "name": {
                    "example": "Starter Keyboard",
                    "type": "string"
                  },
                  "price": {
                    "example": 4900,
                    "type": "integer"
                  },
                  "sku": {
                    "example": "sku_1001",
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "headers": {
          "properties": {
            "x-mock-source": {
              "example": "catalog-promo",
              "type": "string"
            }
          },
          "required": [
            "x-mock-source"
          ],
          "type": "object"
        },
        "mediaType": "application/json",
        "status": "200"
      }
    }
  },
  "operationId": "list-products",
  "resolverUrl": "/internal/mock-data/storefront-browser-lab/storefront-api/list-products",
  "runtimeUrl": "/mocks/rest/storefront-browser-lab/storefront-api/catalog/products?scenario=promo",
  "suite": "storefront-browser-lab"
}
