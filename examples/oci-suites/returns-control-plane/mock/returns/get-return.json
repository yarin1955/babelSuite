{
  "$schema": "https://schemas.babelsuite.dev/mock-exchange-source-v1.json",
  "adapter": "rest",
  "artifact": "mock/returns/get-return.json",
  "contractPath": "api/openapi/returns.yaml#/paths/~1returns~1{returnId}/get",
  "dispatcher": "apisix",
  "examples": {
    "return-state": {
      "dispatch": [],
      "requestSchema": {
        "body": {
          "type": "null"
        },
        "headers": {
          "properties": {
            "x-request-id": {
              "example": "req-100",
              "type": "string"
            }
          },
          "required": [
            "x-request-id"
          ],
          "type": "object"
        }
      },
      "responseSchema": {
        "body": {
          "properties": {
            "profile": {
              "type": "string",
              "x-babel-template": "{{ state.profile }}"
            },
            "refundMode": {
              "type": "string",
              "x-babel-template": "{{ state.refundMode }}"
            },
            "returnId": {
              "type": "string",
              "x-babel-template": "{{ request.path.returnId }}"
            },
            "reviewQueue": {
              "type": "string",
              "x-babel-template": "{{ state.reviewQueue }}"
            },
            "servedAt": {
              "type": "string",
              "x-babel-template": "{{ now() }}"
            },
            "servedBy": {
              "type": "string",
              "x-babel-template": "{{ request.headers.x-mock-node || 'apisix-sidecar' }}"
            },
            "status": {
              "type": "string",
              "x-babel-template": "{{ state.status }}"
            },
            "traceId": {
              "type": "string",
              "x-babel-template": "{{ randomUUID() }}"
            }
          },
          "type": "object"
        },
        "headers": {
          "properties": {
            "x-mock-source": {
              "example": "returns-state",
              "type": "string"
            }
          },
          "required": [
            "x-mock-source"
          ],
          "type": "object"
        },
        "mediaType": "application/json",
        "status": "200"
      }
    }
  },
  "operationId": "get-return",
  "resolverUrl": "/internal/mock-data/returns-control-plane/returns-api/get-return",
  "runtimeUrl": "/mocks/rest/returns-control-plane/returns-api/returns/ret_1001",
  "suite": "returns-control-plane"
}
