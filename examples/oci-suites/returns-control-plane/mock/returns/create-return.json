{
  "$schema": "https://schemas.babelsuite.dev/mock-exchange-source-v1.json",
  "adapter": "rest",
  "artifact": "mock/returns/create-return.json",
  "contractPath": "api/openapi/returns.yaml#/paths/~1returns/post",
  "dispatcher": "apisix",
  "examples": {
    "approved-standard": {
      "dispatch": [
        {
          "from": "query",
          "param": "scenario",
          "value": "approved"
        }
      ],
      "requestSchema": {
        "body": {
          "properties": {
            "amountCents": {
              "example": 4200,
              "type": "integer"
            },
            "orderId": {
              "example": "ord_1001",
              "type": "string"
            },
            "returnReason": {
              "example": "damaged",
              "type": "string"
            }
          },
          "type": "object"
        },
        "headers": {
          "properties": {
            "content-type": {
              "example": "application/json",
              "type": "string"
            },
            "x-suite-profile": {
              "example": "canary.yaml",
              "type": "string"
            }
          },
          "required": [
            "content-type",
            "x-suite-profile"
          ],
          "type": "object"
        }
      },
      "responseSchema": {
        "body": {
          "properties": {
            "queue": {
              "example": "auto",
              "type": "string"
            },
            "refundMode": {
              "example": "instant_credit",
              "type": "string"
            },
            "returnId": {
              "type": "string",
              "x-babel-template": "ret_{{ randomInt(1001, 9999) }}"
            },
            "servedAt": {
              "type": "string",
              "x-babel-template": "{{ now() }}"
            },
            "status": {
              "example": "approved",
              "type": "string"
            },
            "traceId": {
              "type": "string",
              "x-babel-template": "{{ randomUUID() }}"
            }
          },
          "type": "object"
        },
        "headers": {
          "properties": {
            "x-mock-source": {
              "example": "returns-approved",
              "type": "string"
            }
          },
          "required": [
            "x-mock-source"
          ],
          "type": "object"
        },
        "mediaType": "application/json",
        "status": "201"
      }
    },
    "manual-review": {
      "dispatch": [
        {
          "from": "query",
          "param": "scenario",
          "value": "manual-review"
        }
      ],
      "requestSchema": {
        "body": {
          "properties": {
            "amountCents": {
              "example": 15900,
              "type": "integer"
            },
            "orderId": {
              "example": "ord_2042",
              "type": "string"
            },
            "returnReason": {
              "example": "suspicious_activity",
              "type": "string"
            }
          },
          "type": "object"
        },
        "headers": {
          "properties": {
            "content-type": {
              "example": "application/json",
              "type": "string"
            },
            "x-suite-profile": {
              "example": "peak.yaml",
              "type": "string"
            }
          },
          "required": [
            "content-type",
            "x-suite-profile"
          ],
          "type": "object"
        }
      },
      "responseSchema": {
        "body": {
          "properties": {
            "queue": {
              "example": "manual",
              "type": "string"
            },
            "refundMode": {
              "example": "agent_review",
              "type": "string"
            },
            "returnId": {
              "type": "string",
              "x-babel-template": "ret_{{ randomInt(2000, 9999) }}"
            },
            "servedAt": {
              "type": "string",
              "x-babel-template": "{{ now() }}"
            },
            "status": {
              "example": "manual_review",
              "type": "string"
            },
            "traceId": {
              "type": "string",
              "x-babel-template": "{{ randomUUID() }}"
            }
          },
          "type": "object"
        },
        "headers": {
          "properties": {
            "x-review-queue": {
              "example": "manual",
              "type": "string"
            }
          },
          "required": [
            "x-review-queue"
          ],
          "type": "object"
        },
        "mediaType": "application/json",
        "status": "202"
      }
    }
  },
  "operationId": "create-return",
  "resolverUrl": "/internal/mock-data/returns-control-plane/returns-api/create-return",
  "runtimeUrl": "/mocks/rest/returns-control-plane/returns-api/returns?scenario=approved",
  "suite": "returns-control-plane"
}
