  "examples": {
    "GetClaimStatus": {
      "dispatch": [
        {
          "from": "header",
          "param": "soapaction",
          "value": "urn:GetClaimStatus"
        }
      ],
      "requestSchema": {
        "body": {
          "example": "\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003csoapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:clm=\"urn:claims:v1\"\u003e\n  \u003csoapenv:Header/\u003e\n  \u003csoapenv:Body\u003e\n    \u003cclm:GetClaimStatusRequest\u003e\n      \u003cclm:ClaimId\u003eclm_2048\u003c/clm:ClaimId\u003e\n    \u003c/clm:GetClaimStatusRequest\u003e\n  \u003c/soapenv:Body\u003e\n\u003c/soapenv:Envelope\u003e",
          "format": "xml",
          "type": "string"
        },
        "headers": {
          "properties": {
            "content-type": {
              "example": "text/xml; charset=utf-8",
              "type": "string"
            },
            "soapaction": {
              "example": "urn:GetClaimStatus",
              "type": "string"
            }
          },
          "required": [
            "content-type",
            "soapaction"
          ],
          "type": "object"
        }
      },
      "responseSchema": {
        "body": {
          "format": "xml",
          "type": "string",
          "x-babel-template": "\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003csoapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:clm=\"urn:claims:v1\"\u003e\n  \u003csoapenv:Body\u003e\n    \u003cclm:GetClaimStatusResponse\u003e\n      \u003cclm:ClaimId\u003eclm_2048\u003c/clm:ClaimId\u003e\n      \u003cclm:Status\u003eIN_REVIEW\u003c/clm:Status\u003e\n      \u003cclm:Owner\u003emanual_queue\u003c/clm:Owner\u003e\n      \u003cclm:TraceId\u003e{{ randomUUID() }}\u003c/clm:TraceId\u003e\n      \u003cclm:ServedAt\u003e{{ now() }}\u003c/clm:ServedAt\u003e\n    \u003c/clm:GetClaimStatusResponse\u003e\n  \u003c/soapenv:Body\u003e\n\u003c/soapenv:Envelope\u003e"
        },
        "headers": {
          "properties": {
            "x-mock-source": {
              "example": "soap-claim-status",
              "type": "string"
            }
          },
          "required": [
            "x-mock-source"
          ],
          "type": "object"
        },
        "mediaType": "text/xml; charset=utf-8",
        "status": "200"
      }
    },
    "SubmitClaim": {
      "dispatch": [
        {
          "from": "header",
          "param": "soapaction",
          "value": "urn:SubmitClaim"
        }
      ],
      "requestSchema": {
        "body": {
          "example": "\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003csoapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:clm=\"urn:claims:v1\"\u003e\n  \u003csoapenv:Header/\u003e\n  \u003csoapenv:Body\u003e\n    \u003cclm:SubmitClaimRequest\u003e\n      \u003cclm:PolicyNumber\u003ePL-1024\u003c/clm:PolicyNumber\u003e\n      \u003cclm:LossType\u003ewater\u003c/clm:LossType\u003e\n      \u003cclm:Amount\u003e4200\u003c/clm:Amount\u003e\n    \u003c/clm:SubmitClaimRequest\u003e\n  \u003c/soapenv:Body\u003e\n\u003c/soapenv:Envelope\u003e",
          "format": "xml",
          "type": "string"
        },
        "headers": {
          "properties": {
            "content-type": {
              "example": "text/xml; charset=utf-8",
              "type": "string"
            },
            "soapaction": {
              "example": "urn:SubmitClaim",
              "type": "string"
            },
            "x-suite-profile": {
              "example": "canary.yaml",
              "type": "string"
            }
          },
          "required": [
            "content-type",
            "soapaction",
            "x-suite-profile"
          ],
          "type": "object"
        }
      },
      "responseSchema": {
        "body": {
          "format": "xml",
          "type": "string",
          "x-babel-template": "\u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n\u003csoapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:clm=\"urn:claims:v1\"\u003e\n  \u003csoapenv:Body\u003e\n    \u003cclm:SubmitClaimResponse\u003e\n      \u003cclm:ClaimId\u003eclm_{{ randomInt(1001, 9999) }}\u003c/clm:ClaimId\u003e\n      \u003cclm:Decision\u003eAPPROVED\u003c/clm:Decision\u003e\n      \u003cclm:Profile\u003e{{ request.headers.x-suite-profile || 'local.yaml' }}\u003c/clm:Profile\u003e\n      \u003cclm:TraceId\u003e{{ randomUUID() }}\u003c/clm:TraceId\u003e\n      \u003cclm:ServedAt\u003e{{ now() }}\u003c/clm:ServedAt\u003e\n    \u003c/clm:SubmitClaimResponse\u003e\n  \u003c/soapenv:Body\u003e\n\u003c/soapenv:Envelope\u003e"
        },
        "headers": {
          "properties": {
            "x-mock-source": {
              "example": "soap-submit-claim",
              "type": "string"
            }
          },
          "required": [
            "x-mock-source"
          ],
          "type": "object"
        },
        "mediaType": "text/xml; charset=utf-8",
        "status": "200"
      }
    }
  },
  "operationId": "claim-service",
  "resolverUrl": "/internal/mock-data/soap-claims-hub/claims-soap/claim-service",
  "runtimeUrl": "/mocks/rest/soap-claims-hub/claims-soap/ClaimService",
  "suite": "soap-claims-hub"
}
