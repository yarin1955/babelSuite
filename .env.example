# Shared development environment for BabelSuite
# Backend defaults to MongoDB. Uncomment the PostgreSQL block if you want that instead.

PORT=8090
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8090
JWT_SECRET=dev-secret
ADMIN_EMAIL=admin@babelsuite.test
ADMIN_PASSWORD=admin

DB_DRIVER=mongo
MONGO_URI=mongodb://localhost:27017
MONGO_DB=babelsuite
PLATFORM_SETTINGS_FILE=babelsuite-config.yaml
PROFILES_FILE=babelsuite-profiles.yaml

# DB_DRIVER=postgres
# POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/babelsuite?sslmode=disable

# Optional SSO start URLs
# GITHUB_OAUTH_URL=
# GITLAB_OAUTH_URL=
